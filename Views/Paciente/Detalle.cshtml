@model CitasApp.Models.Paciente

<div class="container mt-4">

    <h2 class="mb-4">Información del Paciente</h2>

    <div class="mb-3">
        <a href="/Paciente" class="btn btn-outline-primary">Pacientes</a>
        <a href="/Medico" class="btn btn-outline-success">Médicos</a>
        <a href="/Cita" class="btn btn-outline-warning">Citas</a>
    </div>

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            Datos del Paciente
        </div>

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-6">
                    <strong>ID:</strong>
                    <p>@Model.Id</p>
                </div>

                <div class="col-md-6">
                    <strong>Nombre:</strong>
                    <p>@Model.Nombre</p>
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-md-6">
                    <strong>Apellido:</strong>
                    <p>@Model.Apellido</p>
                </div>

                <div class="col-md-6">
                    <strong>Correo Electrónico:</strong>
                    <p>@Model.Email</p>
                </div>

            </div>

            <div class="mb-3">
                <strong>Teléfono:</strong>
                <p>@Model.Telefono</p>
            </div>

        </div>

        <div class="card-footer d-flex gap-2">

            <a href="/Paciente" class="btn btn-secondary">
                Regresar
            </a>

            <a href="/Cita/PorPaciente?pacienteId=@Model.Id"
               class="btn btn-warning">
                Ver Citas
            </a>

        </div>

    </div>

</div>