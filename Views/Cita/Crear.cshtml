@model CitasApp.Models.Cita

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Registrar Nueva Cita</h3>
        </div>

        <div class="card-body">
            <form asp-action="Crear" method="post">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Paciente</label>
                        <select asp-for="PacienteId" asp-items="ViewBag.Pacientes" class="form-select">
                            <option value="">Seleccione un paciente</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Médico</label>
                        <select asp-for="MedicoId" asp-items="ViewBag.Medicos" class="form-select">
                            <option value="">Seleccione un médico</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Fecha de la cita</label>
                        <input asp-for="Fecha" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Hora de la cita</label>
                        <input asp-for="Hora" type="time" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Motivo de la consulta</label>
                    <textarea asp-for="Motivo" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Estado de la cita</label>
                    <select asp-for="Estado" class="form-select">
                        <option value="Pendiente">Pendiente</option>
                        <option value="Confirmada">Confirmada</option>
                        <option value="Cancelada">Cancelada</option>
                    </select>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-controller="Cita" asp-action="Index" class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-success">
                        Guardar Cita
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
