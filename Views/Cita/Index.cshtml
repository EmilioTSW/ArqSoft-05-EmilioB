@model List<CitasApp.Models.Cita>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📅 Agenda de Citas Médicas</h2>

        <a asp-controller="Cita" asp-action="Crear" class="btn btn-success">
            Nueva Cita
        </a>
    </div>

    <div class="mb-4">
        <a asp-controller="Paciente" asp-action="Index" class="btn btn-outline-primary">
            Pacientes
        </a>

        <a asp-controller="Medico" asp-action="Index" class="btn btn-outline-success">
            Médicos
        </a>

        <a asp-controller="Cita" asp-action="Index" class="btn btn-outline-warning">
            Citas
        </a>
    </div>

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Listado General</h5>
        </div>

        <div class="card-body">

            <table class="table table-hover table-striped">
                <thead class="table-secondary">
                    <tr>
                        <th>ID</th>
                        <th>Paciente</th>
                        <th>Médico</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Motivo</th>
                        <th>Estado</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td>@cita.Id</td>
                            <td>@cita.PacienteId</td>
                            <td>@cita.MedicoId</td>
                            <td>@cita.Fecha.ToShortDateString()</td>
                            <td>@cita.Hora</td>
                            <td>@cita.Motivo</td>

                            <td>
                                @if (cita.Estado == "Confirmada")
                                {
                                    <span class="badge bg-success">
                                        @cita.Estado
                                    </span>
                                }
                                else if (cita.Estado == "Pendiente")
                                {
                                    <span class="badge bg-warning text-dark">
                                        @cita.Estado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        @cita.Estado
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>