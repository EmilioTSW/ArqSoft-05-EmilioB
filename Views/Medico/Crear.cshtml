@model CitasApp.Models.Medico

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h3 class="mb-0">Registrar Médico</h3>
        </div>

        <div class="card-body">

            <form asp-action="Crear" method="post">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Apellido</label>
                        <input asp-for="Apellido" class="form-control" placeholder="Ingrese el apellido" />
                    </div>

                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Especialidad</label>
                    <input asp-for="Especialidad" class="form-control" placeholder="Ingrese la especialidad" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Número de Licencia</label>
                    <input asp-for="NumeroLicencia" class="form-control" placeholder="Ej. LIC-1234" />
                </div>

                <div class="d-flex justify-content-end gap-2">

                    <a href="/Medico" class="btn btn-outline-secondary">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-success">
                        Guardar Médico
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>