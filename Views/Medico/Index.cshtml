@model List<CitasApp.Models.Medico>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Médicos Disponibles</h2>

        <a href="/Medico/Crear" class="btn btn-success">
            Agregar Médico
        </a>
    </div>

    <div class="mb-4">
        <a href="/Paciente" class="btn btn-outline-primary">Pacientes</a>
        <a href="/Medico" class="btn btn-outline-success">Médicos</a>
        <a href="/Cita" class="btn btn-outline-warning">Citas</a>
    </div>

    <div class="card shadow">

        <div class="card-header bg-success text-white">
            Directorio Médico
        </div>

        <div class="card-body">

            <table class="table table-hover table-striped align-middle">

                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Especialidad</th>
                        <th>Licencia</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var medico in Model)
                    {
                        <tr>
                            <td>@medico.Id</td>
                            <td>@medico.Nombre</td>
                            <td>@medico.Apellido</td>
                            <td>@medico.Especialidad</td>
                            <td>@medico.NumeroLicencia</td>

                            <td>
                                <a href="/Medico/Detalle/@medico.Id"
                                   class="btn btn-info btn-sm text-white">
                                    Ver Detalle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>